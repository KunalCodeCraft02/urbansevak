<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Track Booking - HITECH</title>
    <link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;500;600;700;800&family=DM+Sans:ital,wght@0,300;0,400;0,500;0,600;1,400&display=swap" rel="stylesheet">
    <style>
        :root {
            --green: #00C46A;
            --green-dark: #009952;
            --green-dim: rgba(0, 196, 106, 0.12);
            --bg: #0A0B0F;
            --bg2: #0F1117;
            --surface: #1A1D27;
            --border: rgba(255,255,255,0.07);
            --text: #F0F1F5;
            --text-muted: #7B8094;
            --text-dim: #4A4F65;
            --radius: 14px;
            --radius-sm: 8px;
        }

        *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }
        body {
            font-family: 'DM Sans', sans-serif;
            background: var(--bg);
            color: var(--text);
            min-height: 100vh;
            -webkit-font-smoothing: antialiased;
        }

        /* NAVBAR */
        .navbar {
            position: sticky; top: 0; z-index: 1000;
            background: rgba(10, 11, 15, 0.85);
            backdrop-filter: blur(20px);
            border-bottom: 1px solid var(--border);
        }
        .nav-inner {
            max-width: 1400px; margin: auto;
            padding: 0 40px; height: 72px;
            display: flex; align-items: center; gap: 32px;
        }
        .logo-text {
            font-family: 'Syne', sans-serif;
            font-size: 22px; font-weight: 800;
            color: var(--text); text-decoration: none;
        }
        .logo-text span { color: var(--green); }
        .nav-links { display: flex; align-items: center; gap: 8px; margin-left: auto; }
        .nav-links a {
            text-decoration: none; color: var(--text-muted);
            font-size: 14px; font-weight: 500;
            padding: 6px 14px; border-radius: var(--radius-sm);
            transition: all 0.2s;
        }
        .nav-links a:hover { color: var(--text); background: rgba(255,255,255,0.05); }
        .btn-ghost {
            padding: 8px 18px; background: transparent;
            color: var(--text-muted); border: 1px solid var(--border);
            border-radius: var(--radius-sm); font-size: 14px;
            font-weight: 500; cursor: pointer; transition: all 0.2s;
            text-decoration: none;
        }
        .btn-ghost:hover { border-color: rgba(255,255,255,0.2); color: var(--text); }
        .btn-primary {
            padding: 8px 20px; background: var(--green);
            color: #000; border: none; border-radius: var(--radius-sm);
            font-size: 14px; font-weight: 700; cursor: pointer;
            transition: all 0.2s; text-decoration: none;
        }
        .btn-primary:hover { background: #00d975; box-shadow: 0 0 20px rgba(0,196,106,0.4); }

        /* MAIN */
        .main { max-width: 800px; margin: auto; padding: 60px 32px 80px; }

        /* TRACK CARD */
        .track-card {
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: var(--radius);
            padding: 40px;
            margin-bottom: 30px;
        }
        .track-header { text-align: center; margin-bottom: 30px; }
        .track-header h1 {
            font-family: 'Syne', sans-serif;
            font-size: 28px; font-weight: 800;
            color: var(--text); margin-bottom: 8px;
        }
        .track-header p { color: var(--text-muted); font-size: 15px; }

        .field { margin-bottom: 18px; }
        .field label {
            display: block; font-size: 12px; font-weight: 600;
            color: var(--text-muted); margin-bottom: 6px;
            text-transform: uppercase; letter-spacing: 0.5px;
        }
        .field input {
            width: 100%; padding: 14px 16px;
            border: 1px solid var(--border);
            border-radius: var(--radius-sm);
            font-size: 15px; color: var(--text);
            background: var(--bg2); outline: none;
            transition: border-color 0.2s, box-shadow 0.2s;
            font-family: 'DM Sans', sans-serif;
        }
        .field input:focus {
            border-color: var(--green);
            box-shadow: 0 0 0 3px var(--green-dim);
        }

        .track-btn {
            width: 100%; padding: 14px 16px;
            background: var(--green); color: #000;
            border: none; border-radius: var(--radius-sm);
            font-family: 'DM Sans', sans-serif;
            font-size: 15px; font-weight: 700;
            cursor: pointer; transition: all 0.2s;
        }
        .track-btn:hover {
            background: #00d975;
            box-shadow: 0 0 20px rgba(0,196,106,0.4);
        }

        /* BOOKING LIST */
        .booking-list { margin-top: 20px; }
        .booking-card {
            background: var(--bg2);
            border: 1px solid var(--border);
            border-radius: var(--radius);
            padding: 20px;
            margin-bottom: 16px;
            transition: border-color 0.2s;
        }
        .booking-card:hover { border-color: rgba(255,255,255,0.12); }

        .booking-header {
            display: flex; align-items: center;
            justify-content: space-between; margin-bottom: 12px;
        }
        .booking-provider { font-weight: 600; color: var(--text); }
        .booking-date { font-size: 13px; color: var(--text-dim); }

        .status-badge {
            display: inline-block; padding: 4px 12px;
            border-radius: 20px; font-size: 12px; font-weight: 600;
        }
        .status-pending { background: rgba(255,190,91,0.15); color: #ffbe5b; }
        .status-accepted { background: var(--green-dim); color: var(--green); }
        .status-rejected { background: rgba(231,76,60,0.15); color: #e74c3c; }
        .status-completed { background: rgba(13,202,240,0.15); color: #0dcaf0; }

        .booking-detail {
            font-size: 14px; color: var(--text-muted);
            margin-bottom: 6px;
        }
        .booking-detail strong { color: var(--text); }

        .otp-display {
            background: rgba(0,196,106,0.1);
            border: 1px solid rgba(0,196,106,0.3);
            border-radius: 8px; padding: 12px;
            text-align: center; margin-top: 12px;
        }
        .otp-label { font-size: 12px; color: var(--text-dim); margin-bottom: 4px; }
        .otp-code {
            font-size: 32px; font-weight: 800;
            color: var(--green); letter-spacing: 6px;
        }

        .empty-state {
            text-align: center; padding: 40px 20px;
            color: var(--text-dim);
        }
        .empty-state-icon { font-size: 48px; margin-bottom: 16px; opacity: 0.4; }
        .empty-state h3 { font-size: 18px; color: var(--text); margin-bottom: 8px; }
        .empty-state p { font-size: 14px; }

        /* TOAST NOTIFICATION */
        .toast-container {
            position: fixed; top: 20px; right: 20px;
            z-index: 9999; display: flex; flex-direction: column;
            gap: 10px;
        }
        .toast {
            background: var(--surface);
            border: 1px solid rgba(0,196,106,0.4);
            border-radius: var(--radius);
            padding: 16px 20px;
            min-width: 320px;
            box-shadow: 0 8px 32px rgba(0,0,0,0.4), 0 0 40px rgba(0,196,106,0.1);
            animation: slideIn 0.3s ease both;
            display: flex; align-items: flex-start; gap: 12px;
        }
        .toast.error {
            border-color: rgba(231,76,60,0.4);
            box-shadow: 0 8px 32px rgba(0,0,0,0.4), 0 0 40px rgba(231,76,60,0.1);
        }
        .toast-icon { font-size: 24px; flex-shrink: 0; }
        .toast-content { flex: 1; }
        .toast-title {
            font-weight: 700; color: var(--text);
            font-size: 15px; margin-bottom: 4px;
        }
        .toast-message { font-size: 13px; color: var(--text-muted); line-height: 1.4; }
        .toast-otp {
            background: rgba(0,196,106,0.1);
            border: 1px solid rgba(0,196,106,0.3);
            border-radius: 6px; padding: 8px 12px;
            text-align: center; margin-top: 8px;
        }
        .toast-otp-code {
            font-size: 24px; font-weight: 800;
            color: var(--green); letter-spacing: 4px;
        }
        .toast-close {
            background: none; border: none;
            color: var(--text-dim); cursor: pointer;
            font-size: 20px; line-height: 1;
            padding: 0; flex-shrink: 0;
        }
        .toast-close:hover { color: var(--text); }
        .toast-progress {
            position: absolute; bottom: 0; left: 0;
            height: 3px; background: var(--green);
            border-radius: 0 0 var(--radius) var(--radius);
            animation: progressBar 10s linear forwards;
        }
        .toast.error .toast-progress { background: #e74c3c; }

        @keyframes slideIn {
            from { opacity: 0; transform: translateX(100px); }
            to { opacity: 1; transform: translateX(0); }
        }
        @keyframes progressBar {
            from { width: 100%; }
            to { width: 0%; }
        }

        /* LOADING SPINNER */
        .spinner {
            width: 40px; height: 40px;
            border: 4px solid var(--bg2);
            border-top-color: var(--green);
            border-radius: 50%;
            animation: spin 0.8s linear infinite;
            margin: 20px auto;
        }
        @keyframes spin { to { transform: rotate(360deg); } }

        /* RESPONSIVE */
        @media (max-width: 768px) {
            .nav-inner { padding: 0 20px; height: 64px; }
            .main { padding: 30px 16px 60px; }
            .track-card { padding: 24px; }
            .toast-container { top: 10px; right: 10px; left: 10px; }
            .toast { min-width: auto; }
        }
    </style>
</head>
<body>

    <!-- NAVBAR -->
    <nav class="navbar">
        <div class="nav-inner">
            <a href="/" class="logo-text">HI<span>TECH</span></a>
            <div class="nav-links">
                <a href="/">Home</a>
                <a href="/login">Log In</a>
                <a href="/signupas">Sign Up</a>
            </div>
            <a href="/sprovidersignup" class="btn-ghost">Become a Provider</a>
        </div>
    </nav>

    <!-- MAIN CONTENT -->
    <div class="main">
        <div class="track-card">
            <div class="track-header">
                <h1>📍 Track Your Booking</h1>
                <p>Enter your phone number to check booking status and receive OTP notifications</p>
            </div>

            <div class="field">
                <label for="phoneInput">📞 Phone Number</label>
                <input type="tel" id="phoneInput" placeholder="Enter your phone number" autocomplete="off">
            </div>
            <button class="track-btn" onclick="trackBookings()">🔍 Track Bookings</button>
        </div>

        <!-- BOOKING LIST -->
        <div id="bookingList"></div>
    </div>

    <!-- TOAST CONTAINER -->
    <div class="toast-container" id="toastContainer"></div>

    <script>
        let pollingInterval = null;
        let lastBookingStatuses = {};

        // Auto-fill phone from URL parameter and start tracking
        window.addEventListener("DOMContentLoaded", () => {
            const urlParams = new URLSearchParams(window.location.search);
            const phone = urlParams.get("phone");
            if (phone) {
                document.getElementById("phoneInput").value = phone;
                trackBookings();
            }
        });

        function trackBookings() {
            const phone = document.getElementById("phoneInput").value.trim();
            if (!phone) {
                showToast("Error", "Please enter your phone number", "error");
                return;
            }

            // Clear previous polling
            if (pollingInterval) {
                clearInterval(pollingInterval);
            }

            // Initial load
            loadBookings(phone);

            // Start polling every 5 seconds
            pollingInterval = setInterval(() => {
                loadBookings(phone, true);
            }, 5000);
        }

        async function loadBookings(phone, silent = false) {
            try {
                const res = await fetch(`/api/bookings-by-phone/${encodeURIComponent(phone)}`);
                const bookings = await res.json();

                if (!silent) {
                    renderBookings(bookings);
                } else {
                    // Check for status changes
                    bookings.forEach(b => {
                        const prevStatus = lastBookingStatuses[b._id];
                        if (prevStatus && prevStatus !== b.status) {
                            if (b.status === 'accepted') {
                                showToast(
                                    "Booking Accepted! 🎉",
                                    "Your service booking has been accepted. Share the OTP with your provider.",
                                    "success",
                                    b.otp
                                );
                            } else if (b.status === 'rejected') {
                                showToast(
                                    "Booking Rejected",
                                    "Sorry, your booking request was rejected by the provider.",
                                    "error"
                                );
                            } else if (b.status === 'completed') {
                                showToast(
                                    "Work Completed! ✅",
                                    "Your service has been marked as completed.",
                                    "success"
                                );
                            }
                        }
                        lastBookingStatuses[b._id] = b.status;
                    });
                    renderBookings(bookings);
                }

                // Store current statuses
                bookings.forEach(b => {
                    if (!lastBookingStatuses[b._id]) {
                        lastBookingStatuses[b._id] = b.status;
                    }
                });
            } catch (err) {
                if (!silent) {
                    console.error("Error loading bookings:", err);
                    showToast("Error", "Failed to load bookings. Please try again.", "error");
                }
            }
        }

        function renderBookings(bookings) {
            const container = document.getElementById("bookingList");

            if (bookings.length === 0) {
                container.innerHTML = `
                    <div class="empty-state">
                        <div class="empty-state-icon">📭</div>
                        <h3>No bookings found</h3>
                        <p>No bookings found for this phone number. Please check the number and try again.</p>
                    </div>
                `;
                return;
            }

            container.innerHTML = bookings.map(b => `
                <div class="booking-card">
                    <div class="booking-header">
                        <div>
                            <div class="booking-provider">${b.provider ? b.provider.name : 'Provider'}</div>
                            <div class="booking-date">${new Date(b.createdAt).toLocaleString()}</div>
                        </div>
                        <span class="status-badge status-${b.status}">${b.status}</span>
                    </div>
                    <div class="booking-detail"><strong>Work:</strong> ${b.workDescription}</div>
                    <div class="booking-detail"><strong>Address:</strong> ${b.customerAddress}</div>
                    <div class="booking-detail"><strong>Phone:</strong> ${b.customerPhone}</div>
                    ${b.provider ? `<div class="booking-detail"><strong>Provider Phone:</strong> ${b.provider.phone}</div>` : ''}
                    ${b.status === 'accepted' && b.otp ? `
                        <div class="otp-display">
                            <div class="otp-label">Your OTP (Share with Provider)</div>
                            <div class="otp-code">${b.otp}</div>
                        </div>
                    ` : ''}
                </div>
            `).join('');
        }

        function showToast(title, message, type = "success", otp = null) {
            const container = document.getElementById("toastContainer");

            const toast = document.createElement("div");
            toast.className = `toast ${type === "error" ? "error" : ""}`;
            toast.style.position = "relative";
            toast.style.overflow = "hidden";

            toast.innerHTML = `
                <div class="toast-icon">${type === "error" ? "❌" : "✅"}</div>
                <div class="toast-content">
                    <div class="toast-title">${title}</div>
                    <div class="toast-message">${message}</div>
                    ${otp ? `
                        <div class="toast-otp">
                            <div style="font-size:12px;color:var(--text-dim);margin-bottom:4px;">Your OTP</div>
                            <div class="toast-otp-code">${otp}</div>
                        </div>
                    ` : ''}
                </div>
                <button class="toast-close" onclick="this.parentElement.remove()">×</button>
                <div class="toast-progress"></div>
            `;

            container.appendChild(toast);

            // Auto-remove after 10 seconds
            setTimeout(() => {
                if (toast.parentElement) {
                    toast.style.opacity = "0";
                    toast.style.transform = "translateX(100px)";
                    toast.style.transition = "all 0.3s ease";
                    setTimeout(() => toast.remove(), 300);
                }
            }, 10000);
        }

        // Allow Enter key to trigger search
        document.getElementById("phoneInput").addEventListener("keypress", function(e) {
            if (e.key === "Enter") {
                trackBookings();
            }
        });
    </script>
</body>
</html>
